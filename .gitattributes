# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files — force UTF-8, CRLF on Windows checkout
*.cs     text eol=crlf encoding=utf-8
*.cshtml text eol=crlf encoding=utf-8
*.css    text eol=crlf encoding=utf-8
*.js     text eol=crlf encoding=utf-8
*.json   text eol=crlf encoding=utf-8
*.md     text eol=crlf encoding=utf-8
*.xml    text eol=crlf encoding=utf-8
*.csproj text eol=crlf encoding=utf-8
*.sln    text eol=crlf encoding=utf-8
*.razor  text eol=crlf encoding=utf-8

# Binary files - never modify
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.dll    binary
*.exe    binary
*.db     binary
*.db-shm binary
*.db-wal binary
