@{
    ViewData["Title"] = "Không có quyền truy cập";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-wrapper d-flex align-items-center justify-content-center min-vh-100">
    <div class="auth-card text-center" data-aos="fade-up">
        <div class="mb-3">
            <i class="bi bi-shield-lock text-warning" style="font-size:3rem;"></i>
        </div>
        <h3 class="text-white mb-2">Không có quyền truy cập</h3>
        <p class="text-muted mb-4">
            Tài khoản của bạn không có quyền vào trang này hoặc phiên đăng nhập chưa hợp lệ.
        </p>

        <div class="d-grid gap-2">
            <a asp-controller="Account" asp-action="Login" class="btn btn-premium">
                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập lại
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light">
                <i class="bi bi-house me-2"></i>Về trang chủ
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        if (window.AOS) AOS.init();
    </script>
}
