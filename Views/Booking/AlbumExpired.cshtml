@model PhoStudioMVC.Models.Entities.CloudAlbum
@{
    Layout = "_Layout";
    ViewData["Title"] = "Album đã hết hạn";
}

@section Styles {
<style>
    .expired-header { padding:120px 0 56px; background:linear-gradient(160deg,#1a1208 0%,#2d1f0a 60%,#1a1208 100%); border-bottom:1px solid rgba(203,163,92,.2); text-align:center; }
    .expired-card { background:#fff; border:1.5px solid rgba(239,68,68,.2); border-radius:14px; padding:40px; max-width:500px; margin:0 auto; box-shadow:0 4px 24px rgba(43,43,43,.09); text-align:center; }
</style>
}

<header class="expired-header">
    <div class="container">
        <h1 class="text-white mb-2" style="font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;">Album đã hết hạn</h1>
    </div>
</header>

<section style="background:#F5EFE6;padding:48px 0;min-height:60vh;">
    <div class="container">
        <div class="expired-card" data-aos="fade-up">
            <i class="bi bi-lock-fill mb-3 d-block" style="font-size:3rem;color:#EF4444;"></i>
            <h4 style="font-family:'Playfair Display',serif;color:#2B2B2B;margin-bottom:8px;">Album đã hết hạn</h4>
            <p style="color:#6B6B6B;font-size:.9rem;margin-bottom:20px;">
                Album hết hạn ngày <strong style="color:#EF4444;">@Model.ExpiryDate.ToString("dd/MM/yyyy")</strong>.<br>
                Liên hệ studio để được gia hạn hoặc nhận đường dẫn mới.
            </p>
            <a asp-controller="Client" asp-action="MyAlbums" style="background:#CBA35C;color:#fff;border:none;border-radius:8px;padding:10px 24px;font-weight:600;text-decoration:none;display:inline-block;transition:all .25s ease;" onmouseover="this.style.background='#B8941F'" onmouseout="this.style.background='#CBA35C'">
                <i class="bi bi-arrow-left me-1"></i>Quay lại My Albums
            </a>
        </div>
    </div>
</section>
