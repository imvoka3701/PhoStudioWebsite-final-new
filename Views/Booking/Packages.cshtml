@model IEnumerable<PhoStudioMVC.Models.Entities.ServicePackage>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Các Gói Dịch Vụ";
}

@section Styles {
    <style>
        .page-header {
            padding: 140px 0 72px;
            background:
                linear-gradient(to bottom, rgba(10,6,2,0.72) 0%, rgba(10,6,2,0.60) 100%),
                url('/assets/img/header-img/header-img1.jpg') center/cover no-repeat;
            border-bottom: 1px solid rgba(203,163,92,0.2);
        }

        .page-header h5 {
            color: #E8C47A !important;
            font-size: 0.82rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 16px;
            text-shadow: 0 1px 6px rgba(0,0,0,0.5);
        }

        .page-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.6rem, 5vw, 3.8rem);
            font-weight: 700;
            color: #FFFFFF !important;
            text-transform: none !important;
            letter-spacing: 0 !important;
            margin-bottom: 20px;
            text-shadow: 0 3px 16px rgba(0,0,0,0.55);
        }

        .page-header p {
            color: rgba(255,255,255,0.92) !important;
            font-size: 1.08rem;
            font-weight: 300;
            max-width: 560px;
            margin: 0 auto;
            line-height: 1.8;
            text-shadow: 0 1px 8px rgba(0,0,0,0.4);
        }
        .service-detail-card {
            background: #FFFFFF;
            border: 1px solid #EDE8DF;
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 0 2px 16px rgba(43,43,43,0.07);
        }
        .service-detail-card:hover {
            border-color: #CBA35C;
            transform: translateY(-6px);
            box-shadow: 0 16px 48px rgba(43,43,43,0.13);
        }
        .service-img-wrapper {
            height: 250px;
            overflow: hidden;
        }
        .service-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition-smooth);
        }
        .service-detail-card:hover .service-img-wrapper img {
            transform: scale(1.1);
        }
        .service-content {
            padding: 32px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            background: #FFFFFF;
        }
        .service-content h2 {
            font-family: 'Playfair Display', serif;
            color: #1A1A1A !important;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 8px;
        }
        .service-price {
            font-size: 1.15rem;
            color: #CBA35C;
            font-weight: 600;
            margin-bottom: 16px;
            display: inline-block;
        }
        .service-content p {
            color: #4A4A4A;
            font-size: 0.93rem;
            line-height: 1.7;
        }
        .feature-list {
            list-style: none;
            padding-left: 0;
            margin-bottom: 28px;
            flex-grow: 1;
        }
        .feature-list li {
            margin-bottom: 8px;
            color: #4A4A4A;
            font-size: 0.9rem;
        }
        .feature-list li i {
            color: #CBA35C;
            margin-right: 8px;
        }
    </style>
}

<!-- Page Header -->
<header class="page-header text-center">
    <div class="container" data-aos="fade-up">
        <h5 class="mb-4 letter-spacing-1">CHỌN TRẢI NGHIỆM CỦA BẠN</h5>
        <h1 class="display-3 mb-4">Các Gói Dịch Vụ</h1>
        <p class="max-w-600 mx-auto" style="font-weight: 300; font-size: 1.15rem;">Khám phá các gói chụp được thiết kế đặc biệt để ghi lại những khoảnh khắc quý giá nhất của bạn.</p>
    </div>
</header>

<!-- Services Grid -->
<section style="background:#F5EFE6;padding:80px 0;">
    <div class="container">
        <div class="row g-5">
            @foreach (var pkg in Model)
            {
                <div class="col-lg-6" data-aos="fade-up">
                    <div class="service-detail-card">
                        <div class="service-img-wrapper">
                            @{
                                var imgUrl = pkg.Name switch {
                                    "Gói Ảnh Cưới" => "https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=2069&auto=format&fit=crop",
                                    "Gói Kỷ Yếu" => "https://images.unsplash.com/photo-1523050854058-8df90110c9f1?q=80&w=2070&auto=format&fit=crop",
                                    "Gói Gia Đình" => "https://images.unsplash.com/photo-1581952976147-5a3d15fb320c?q=80&w=2071&auto=format&fit=crop",
                                    _ => "https://images.unsplash.com/photo-1542038784456-1ea8e935640e?q=80&w=2070&auto=format&fit=crop"
                                };
                            }
                            <img src="@imgUrl" alt="@pkg.Name">
                        </div>
                        <div class="service-content">
                            <h2 class="mb-2">@pkg.Name</h2>
                            <div class="service-price">@pkg.Price.ToString("N0") VNĐ</div>
                            <p class="text-muted mb-4">@(string.IsNullOrWhiteSpace(pkg.Description) ? "Trải nghiệm nhiếp ảnh chuyên nghiệp tại Phố Studio." : pkg.Description)</p>
                            <ul class="feature-list">
                                <li><i class="bi bi-clock"></i> Thời lượng: @pkg.DurationMinutes phút</li>
                                <li><i class="bi bi-check2"></i> Chỉnh sửa ảnh chuyên nghiệp</li>
                                <li><i class="bi bi-check2"></i> Trả file qua Cloud Gallery</li>
                                <li><i class="bi bi-check2"></i> Thiết bị ánh sáng hiện đại</li>
                                <li><i class="bi bi-check2"></i> Tư vấn concept miễn phí</li>
                            </ul>
                            <a asp-action="SelectTime" asp-route-packageId="@pkg.Id" 
                               class="btn btn-premium w-100 booking-btn" 
                               data-package-id="@pkg.Id"
                               data-package-name="@pkg.Name"
                               data-package-price="@pkg.Price.ToString("N0")">
                                <span class="btn-text">ĐẶT LỊCH NGAY</span>
                                <span class="btn-loading" style="display: none;">
                                    <i class="bi bi-arrow-right-circle me-2"></i>Đang tải...
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Enhanced booking button interactions
            const bookingButtons = document.querySelectorAll('.booking-btn');
            
            bookingButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    const packageId = this.dataset.packageId;
                    const packageName = this.dataset.packageName;
                    const packagePrice = this.dataset.packagePrice;
                    
                    // Show loading state
                    const btnText = this.querySelector('.btn-text');
                    const btnLoading = this.querySelector('.btn-loading');
                    
                    btnText.style.display = 'none';
                    btnLoading.style.display = 'inline';
                    this.disabled = true;
                    
                    // Store selected package info for potential use on next page
                    sessionStorage.setItem('selectedPackage', JSON.stringify({
                        id: packageId,
                        name: packageName,
                        price: packagePrice
                    }));
                    
                    // Allow navigation to proceed after showing loading state
                    setTimeout(() => {
                        window.location.href = this.href;
                    }, 300);
                });
            });
            
            // Restore selected package info if available
            const selectedPackage = sessionStorage.getItem('selectedPackage');
            if (selectedPackage) {
                sessionStorage.removeItem('selectedPackage'); // Clear after reading
            }
            
            // Add hover effects with smooth transitions
            const serviceCards = document.querySelectorAll('.service-detail-card');
            serviceCards.forEach(card => {
                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-8px) scale(1.02)';
                });
                
                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0) scale(1)';
                });
            });
        });
    </script>
}
