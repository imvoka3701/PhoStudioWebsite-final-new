                </div>
                <div class="points-value">@Model.AvailablePoints</div>
            </div>

            <div class="points-card" data-aos="fade-up" data-aos-delay="100">
                <div class="points-label">
                    <i class="bi bi-graph-up me-2"></i>T?ng ?i?m Ki?m
                </div>
                <div class="points-value">@Model.TotalPoints</div>
            </div>

            <div class="points-card" data-aos="fade-up" data-aos-delay="200">
