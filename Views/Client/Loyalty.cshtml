                    <i class="bi bi-clipboard me-2"></i>Sao Chép
                </button>
            </div>

            <!-- Benefits -->
            <div class="benefits-grid">
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <i class="bi bi-gift"></i>
                    </div>
                    <h5 class="benefit-title">B?n Nh?n</h5>
                    <p class="benefit-desc">100 ?i?m cho l?n ??u</p>
                </div>

                <div class="benefit-card">
                    <div class="benefit-icon">
                        <i class="bi bi-hand-thumbs-up"></i>
                    </div>
                    <h5 class="benefit-title">B?n Bè Nh?n</h5>
                    <p class="benefit-desc">Gi?m 5% cho l?n ??u</p>
                </div>

                <div class="benefit-card">
                    <div class="benefit-icon">
                        <i class="bi bi-infinity"></i>
                    </div>
                    <h5 class="benefit-title">Vô Gi?i H?n</h5>
                    <p class="benefit-desc">Không có gi?i h?n l?n chia s?</p>
                </div>
            </div>
        </div>

        <!-- Transaction History -->
        <div class="transaction-history mt-40" data-aos="fade-up">
            <h3 class="text-white mb-4">
                <i class="bi bi-clock-history me-2"></i>L?ch S? Giao D?ch
            </h3>

            <table class="transaction-table">
                <thead>
                    <tr>
                        <th>Lý Do</th>
                        <th>?i?m</th>
                        <th>Ngày</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <i class="bi bi-calendar-check me-2" style="color: var(--primary-color);"></i>
                            ??t l?ch ch?p
                        </td>
                        <td><span class="points-positive">+150</span></td>
                        <td>01/04/2025</td>
                    </tr>
                    <tr>
                        <td>
                            <i class="bi bi-gift me-2" style="color: var(--primary-color);"></i>
                            B?n bè dùng mã gi?i thi?u
                        </td>
                        <td><span class="points-positive">+100</span></td>
                        <td>31/03/2025</td>
                    </tr>
                    <tr>
                        <td>
                            <i class="bi bi-ticket me-2" style="color: var(--primary-color);"></i>
                            S? d?ng ?i?m tr? giá
                        </td>
                        <td><span class="points-negative">-200</span></td>
                        <td>30/03/2025</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h4>B?n ch?a có thông tin thành viên</h4>
            <p>Hãy t?o booking ??u tiên ?? b?t ??u ki?m ?i?m</p>
            <a href="/Booking/Packages" class="btn btn-primary mt-3">??t L?ch Ngay</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function copyReferralCode() {
            const code = document.getElementById('referralCode').value;
            navigator.clipboard.writeText(code).then(() => {
                alert('? ?ã sao chép mã gi?i thi?u');
            });
        }
    </script>
}
