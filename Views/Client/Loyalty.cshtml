@model PhoStudioMVC.Models.Entities.CustomerLoyalty
@{
    Layout = "_Layout";
    ViewData["Title"] = "Ch??ng Trình Thân Thi?t";
}

@section Styles {
    <style>
        :root {
            --primary-color: #c9a96e;
            --dark-bg: #0f0f0f;
            --card-bg: rgba(30, 30, 30, 0.8);
            --border-color: rgba(201, 169, 110, 0.2);
            --text-muted: #999;
        }

        .loyalty-hero {
            padding: 120px 0 80px;
            background: linear-gradient(135deg, rgba(15,15,15,1) 0%, rgba(5,5,5,1) 100%);
            border-bottom: 1px solid var(--border-color);
        }

        .loyalty-hero h1 {
            font-size: 3.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-color), #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 20px;
        }

        .points-display {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }

        .points-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 32px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .points-card:hover {
            border-color: var(--primary-color);
            transform: translateY(-8px);
            box-shadow: 0 20px 60px rgba(201, 169, 110, 0.1);
        }

        .points-value {
            font-size: 3rem;
            font-weight: 700;
            color: var(--primary-color);
            margin: 16px 0;
        }

        .points-label {
            color: var(--text-muted);
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .membership-tier {
            padding: 40px;
            background: linear-gradient(135deg, rgba(201, 169, 110, 0.1), rgba(212, 175, 122, 0.05));
            border: 1px solid var(--border-color);
            border-radius: 16px;
            text-align: center;
            margin-bottom: 40px;
        }

        .tier-badge {
            display: inline-block;
            padding: 8px 24px;
            background: linear-gradient(135deg, var(--primary-color), #d4af7a);
            color: #000;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.95rem;
            margin-bottom: 16px;
        }

        .tier-progress {
            margin: 32px 0;
        }

        .progress-bar-custom {
            height: 8px;
            background: rgba(201, 169, 110, 0.1);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 16px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary-color), #d4af7a);
            border-radius: 4px;
            transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .tier-info {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .referral-section {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 32px;
            margin-bottom: 40px;
        }

        .referral-code-box {
            display: flex;
            gap: 12px;
            margin: 20px 0;
        }

        .referral-code-input {
            flex: 1;
            background: rgba(201, 169, 110, 0.05);
            border: 2px solid var(--primary-color);
            border-radius: 8px;
            padding: 14px;
            color: var(--primary-color);
            font-family: 'Courier New', monospace;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .referral-code-input:focus {
            outline: none;
            box-shadow: 0 0 20px rgba(201, 169, 110, 0.3);
        }

        .btn-copy {
            background: linear-gradient(135deg, var(--primary-color), #d4af7a);
            color: #000;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-copy:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 30px rgba(201, 169, 110, 0.3);
        }

        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 24px;
            margin-top: 32px;
        }

        .benefit-card {
            background: rgba(201, 169, 110, 0.05);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .benefit-card:hover {
            border-color: var(--primary-color);
            transform: translateY(-6px);
        }

        .benefit-icon {
            font-size: 2.5rem;
            color: var(--primary-color);
            margin-bottom: 16px;
        }

        .benefit-title {
            font-weight: 700;
            margin-bottom: 8px;
        }

        .benefit-desc {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .transaction-history {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 32px;
            overflow-x: auto;
        }

        .transaction-table {
            width: 100%;
            border-collapse: collapse;
        }

        .transaction-table thead {
            border-bottom: 2px solid var(--border-color);
        }

        .transaction-table th {
            color: var(--primary-color);
            text-align: left;
            padding: 16px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
        }

        .transaction-table td {
            padding: 16px;
            border-bottom: 1px solid var(--border-color);
            color: #fff;
        }

        .transaction-table tbody tr:hover {
            background: rgba(201, 169, 110, 0.05);
        }

        .points-positive {
            color: #4ade80;
            font-weight: 700;
        }

        .points-negative {
            color: #ff6b6b;
            font-weight: 700;
        }
    </style>
}

<div class="loyalty-hero">
    <div class="container" data-aos="fade-up">
        <h1><i class="bi bi-star-fill me-3"></i>Ch??ng Trình Thân Thi?t VIP</h1>
        <p class="text-muted mt-3" style="font-size: 1.1rem; font-weight: 300;">
            Tích l?y ?i?m, nh?n ?u ?ãi ??c quy?n
        </p>
    </div>
</div>

<div class="container py-5">
    @if (Model != null)
