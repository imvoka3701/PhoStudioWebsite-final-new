@{
    Layout = "_Layout";
    ViewData["Title"] = "Album Ảnh";
}

@section Styles {
    <style>
        .page-header {
            padding: 140px 0 72px;
            background:
                linear-gradient(to bottom, rgba(10,6,2,0.72) 0%, rgba(10,6,2,0.60) 100%),
                url('/assets/img/header-img/header-img3.jpg') center/cover no-repeat;
            border-bottom: 1px solid rgba(203,163,92,0.2);
        }

        .page-header h5 {
            color: #E8C47A !important;
            font-size: 0.82rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 16px;
            text-shadow: 0 1px 6px rgba(0,0,0,0.5);
        }

        .page-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.6rem, 5vw, 3.8rem);
            font-weight: 700;
            color: #FFFFFF !important;
            text-transform: none !important;
            letter-spacing: 0 !important;
            margin-bottom: 20px;
            text-shadow: 0 3px 16px rgba(0,0,0,0.55);
        }

        .page-header p {
            color: rgba(255,255,255,0.92) !important;
            font-size: 1.08rem;
            font-weight: 300;
            max-width: 560px;
            margin: 0 auto;
            line-height: 1.8;
            text-shadow: 0 1px 8px rgba(0,0,0,0.4);
        }
    </style>
}

<!-- Page Header -->
<header class="page-header text-center">
    <div class="container" data-aos="fade-up">
        <h5 class="mb-4 letter-spacing-1">TÁC PHẨM CỦA CHÚNG TÔI</h5>
        <h1 class="display-3 mb-4">Kể Chuyện Trực Quan</h1>
        <p class="max-w-600 mx-auto" style="font-weight: 300; font-size: 1.15rem;">Bộ sưu tập những khoảnh khắc tuyệt vời nhất, từ những lễ cưới lãng mạn đầy cảm xúc đến chân dung cá nhân thanh lịch.</p>
    </div>
</header>

<!-- Portfolio Gallery -->
<section class="section-padding" style="background: linear-gradient(to bottom, #F5EFE6, #FAF7F2);">
    <div class="container">
        <!-- Filter Options -->
        <div class="text-center mb-5" data-aos="fade-in">
            <button class="btn btn-sm me-2" style="border:1.5px solid #CBA35C;color:#CBA35C;border-radius:8px;padding:6px 18px;font-weight:600;background:transparent;transition:all .25s ease;" onmouseover="this.style.background='#CBA35C';this.style.color='#fff'" onmouseout="this.style.background='transparent';this.style.color='#CBA35C'">Tất Cả</button>
            <button class="btn btn-sm me-2" style="border:1.5px solid #EDE8DF;color:#6B6B6B;border-radius:8px;padding:6px 18px;font-weight:600;background:transparent;transition:all .25s ease;" onmouseover="this.style.borderColor='#CBA35C';this.style.color='#CBA35C'" onmouseout="this.style.borderColor='#EDE8DF';this.style.color='#6B6B6B'">Ảnh Cưới</button>
            <button class="btn btn-sm me-2" style="border:1.5px solid #EDE8DF;color:#6B6B6B;border-radius:8px;padding:6px 18px;font-weight:600;background:transparent;transition:all .25s ease;" onmouseover="this.style.borderColor='#CBA35C';this.style.color='#CBA35C'" onmouseout="this.style.borderColor='#EDE8DF';this.style.color='#6B6B6B'">Kỷ Yếu</button>
            <button class="btn btn-sm" style="border:1.5px solid #EDE8DF;color:#6B6B6B;border-radius:8px;padding:6px 18px;font-weight:600;background:transparent;transition:all .25s ease;" onmouseover="this.style.borderColor='#CBA35C';this.style.color='#CBA35C'" onmouseout="this.style.borderColor='#EDE8DF';this.style.color='#6B6B6B'">Gia Đình</button>
        </div>

        <div class="masonry-grid">
            <!-- Portfolio Items với hình ảnh từ packages -->
            <div class="masonry-item" data-aos="zoom-in" data-aos-delay="100">
                <img src="/assets/img/packages/work1.jpg?v=@DateTime.Now.Ticks@DateTime.Now.Millisecond" class="pf-img" alt="Work 1">
                <div class="pf-overlay">
                    <h4 class="text-white">Tác Phẩm 1</h4>
                    <span class="text-accent small">Portfolio</span>
                </div>
            </div>
