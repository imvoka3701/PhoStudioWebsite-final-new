@{
    Layout = "_Layout";
    ViewData["Title"] = "Dịch Vụ";
}

@section Styles {
    <style>
        .page-header {
            padding: 140px 0 72px;
            background:
                linear-gradient(to bottom, rgba(10,6,2,0.72) 0%, rgba(10,6,2,0.60) 100%),
                url('/assets/img/header-img/header-img2.jpg') center/cover no-repeat;
            border-bottom: 1px solid rgba(203,163,92,0.2);
        }

        .page-header h5 {
            color: #E8C47A !important;
            font-size: 0.82rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 16px;
            text-shadow: 0 1px 6px rgba(0,0,0,0.5);
        }

        .page-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.6rem, 5vw, 3.8rem);
            font-weight: 700;
            color: #FFFFFF !important;
            text-transform: none !important;
            letter-spacing: 0 !important;
            margin-bottom: 20px;
            text-shadow: 0 3px 16px rgba(0,0,0,0.55);
        }

        .page-header p {
            color: rgba(255,255,255,0.92) !important;
            font-size: 1.08rem;
            font-weight: 300;
            max-width: 560px;
            margin: 0 auto;
            line-height: 1.8;
            text-shadow: 0 1px 8px rgba(0,0,0,0.4);
        }
        .service-detail-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            overflow: hidden;
            transition: var(--transition-smooth);
            height: 100%;
        }
        .service-detail-card:hover {
            border-color: var(--accent-color);
            transform: translateY(-5px);
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        }
        .service-img-wrapper {
            height: 250px;
            overflow: hidden;
        }
        .service-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition-smooth);
        }
        .service-detail-card:hover .service-img-wrapper img {
            transform: scale(1.1);
        }
        .service-content {
            padding: 40px;
        }
        .service-price {
            font-size: 1.25rem;
            color: var(--accent-color);
            font-weight: 500;
            margin-bottom: 20px;
            display: inline-block;
            border-bottom: 1px solid var(--accent-color);
            padding-bottom: 5px;
        }
        .feature-list {
            list-style: none;
            padding-left: 0;
            margin-bottom: 30px;
        }
        .feature-list li {
            margin-bottom: 10px;
            color: var(--text-muted);
        }
        .feature-list li i {
            color: var(--accent-color);
            margin-right: 10px;
        }
    </style>
}

<!-- Page Header -->
<header class="page-header text-center">
    <div class="container" data-aos="fade-up">
        <h5 class="mb-4 letter-spacing-1">CHÚNG TÔI CUNG CẤP GÌ</h5>
        <h1 class="display-3 mb-4">Các Gói Dịch Vụ</h1>
        <p class="max-w-600 mx-auto" style="font-weight: 300; font-size: 1.15rem;">Trải nghiệm nhiếp ảnh được thiết kế riêng nhằm lưu giữ câu chuyện độc bản của bạn với phong cách điện ảnh thanh lịch.</p>
    </div>
</header>

<!-- Services Grid -->
<section class="section-padding">
    <div class="container">
        <div class="row g-5">
            
            <!-- Wedding -->
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                <div class="service-detail-card">
                    <div class="service-img-wrapper">
                        <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=2069&auto=format&fit=crop" alt="Wedding Photography">
                    </div>
                    <div class="service-content">
                        <h2 class="text-white mb-2">Ảnh Cưới / Phóng Sự</h2>
                        <div class="service-price">Từ 15.000.000 VNĐ</div>
                        <p class="text-muted mb-4">Lưu giữ trọn vẹn ngày trọng đại từ khâu chuẩn bị đến điệu nhảy cuối cùng, chất lượng độ phân giải cao.</p>
                        <ul class="feature-list">
                            <li><i class="bi bi-check2"></i> Chụp trọn ngày (8-10 tiếng)</li>
                            <li><i class="bi bi-check2"></i> Hai thợ nháy (photographers) chuyên nghiệp</li>
                            <li><i class="bi bi-check2"></i> 500+ ảnh retouched độ phân giải cao</li>
                            <li><i class="bi bi-check2"></i> Album cao cấp bọc da/mica</li>
                            <li><i class="bi bi-check2"></i> Thư viện ảnh gallery trực tuyến</li>
                        </ul>
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-premium w-100">Đặt Lịch Cưới</a>
                    </div>
                </div>
            </div>

            <!-- Graduation -->
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="200">
                <div class="service-detail-card">
                    <div class="service-img-wrapper">
                        <img src="/assets/img/packages/ki-yeu.jpg?v=@DateTime.Now.Ticks@DateTime.Now.Millisecond" alt="Graduation Portraits">
                    </div>
                    <div class="service-content">
                        <h2 class="text-white mb-2">Chụp Kỷ Yếu Cá Nhân</h2>
                        <div class="service-price">Từ 1.500.000 VNĐ</div>
                        <p class="text-muted mb-4">Kỷ niệm thành tựu học thuật bằng những bức chân dung thanh lịch quanh khuôn viên trường hoặc tại studio.</p>
                        <ul class="feature-list">
                            <li><i class="bi bi-check2"></i> Buổi chụp 2 tiếng tại trường hoặc studio</li>
                            <li><i class="bi bi-check2"></i> Cho phép thay đổi nhiều trang phục</li>
                            <li><i class="bi bi-check2"></i> 50 ảnh được chỉnh sửa chuyên nghiệp</li>
                            <li><i class="bi bi-check2"></i> Miễn phí trang phục hoa tú cầu/đạo cụ</li>
                            <li><i class="bi bi-check2"></i> Tặng kèm một thiết kế photobook điện tử</li>
                        </ul>
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-premium w-100">Đặt Lịch Kỷ Yếu</a>
                    </div>
                </div>
            </div>

            <!-- Family -->
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="300">
                <div class="service-detail-card">
                    <div class="service-img-wrapper">
                        <img src="/assets/img/packages/gia-dinh.jpg?v=@DateTime.Now.Ticks@DateTime.Now.Millisecond" alt="Family Photography">
                    </div>
                    <div class="service-content">
                        <h2 class="text-white mb-2">Chụp Ảnh Gia Đình</h2>
                        <div class="service-price">Từ 2.000.000 VNĐ</div>
                        <p class="text-muted mb-4">Bức chân dung vượt thời gian ghi lại sự gắn kết của đại gia đình, tạo nên báu vật lưu truyền qua các thế hệ.</p>
                        <ul class="feature-list">
                            <li><i class="bi bi-check2"></i> Buổi chụp 3 tiếng ngoài trời hoặc studio</li>
                            <li><i class="bi bi-check2"></i> Dành cho gia đình từ 3 - 6 thành viên</li>
                            <li><i class="bi bi-check2"></i> Trả 100 file ảnh qua chỉnh màu HDR</li>
                            <li><i class="bi bi-check2"></i> Gói tư vấn in ấn và setup ảnh gỗ ép</li>
                            <li><i class="bi bi-check2"></i> Makeup miễn phí cho mẹ và bé gái</li>
                        </ul>
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-premium w-100">Đặt Lịch Gia Đình</a>
                    </div>
                </div>
            </div>

            <!-- Studio -->
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="400">
                <div class="service-detail-card">
                    <div class="service-img-wrapper">
                        <img src="https://images.unsplash.com/photo-1542038784456-1ea8e935640e?q=80&w=2070&auto=format&fit=crop" alt="Studio Fashion">
                    </div>
                    <div class="service-content">
                        <h2 class="text-white mb-2">Studio & Profile</h2>
                        <div class="service-price">Từ 4.000.000 VNĐ</div>
                        <p class="text-muted mb-4">Ảnh phong cách tạp chí cao cấp dùng cho xây dựng thương hiệu cá nhân, hồ sơ người mẫu hoặc thể hiện cái tôi nghệ thuật.</p>
                        <ul class="feature-list">
                            <li><i class="bi bi-check2"></i> Sử dụng toàn bộ bối cảnh Phố Studio</li>
                            <li><i class="bi bi-check2"></i> Hỗ trợ concept & stylist chuyên nghiệp</li>
                            <li><i class="bi bi-check2"></i> Hệ thống thiết bị ánh sáng cinema chuẩn</li>
                            <li><i class="bi bi-check2"></i> Chỉnh sửa (retouch) beauty cao cấp da & hình thể</li>
                            <li><i class="bi bi-check2"></i> Đã bao gồm license sử dụng thương mại</li>
                        </ul>
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-premium w-100">Đặt Lịch Profile</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
