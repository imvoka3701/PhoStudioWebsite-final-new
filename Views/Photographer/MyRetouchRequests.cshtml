@model List<PhoStudioMVC.Models.Entities.RetouchRequest>
@{
    ViewData["Title"] = "Yêu cầu chỉnh sửa ảnh";
    Layout = "~/Views/Shared/_PhotographerLayout.cshtml";
}

<div style="background:var(--bg-card);border-bottom:1px solid var(--border-light);padding:28px 32px;margin:-32px -32px 32px -32px;box-shadow:var(--shadow-sm);">
    <h1 style="font-family:'Playfair Display',serif;font-size:1.75rem;font-weight:700;color:var(--text-dark);margin:0 0 4px 0;">
        🎨 Yêu cầu Retouch của tôi
    </h1>
    <p style="color:var(--text-muted);font-size:0.9rem;margin:0;">Các yêu cầu chỉnh sửa ảnh từ khách hàng cần xử lý.</p>
</div>

@if (!Model.Any())
{
    <div class="dash-card text-center py-5">
        <i class="bi bi-check-circle-fill fs-1 mb-3 d-block" style="color:var(--success);"></i>
        <h5 style="color:var(--text-dark);">Tất cả đã xong!</h5>
        <p style="color:var(--text-muted);">Không có yêu cầu retouch nào đang chờ xử lý.</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var r in Model)
        {
            <div class="dash-card">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <div>
                        <h6 style="color:var(--text-dark);font-weight:600;margin-bottom:4px;">
                            Lịch #@(r.Booking?.Id?.PadLeft(6, '0') ?? "—") — @(r.Booking?.Client?.FullName ?? "—")
                            <span class="badge ms-2" style="background:var(--info-bg);color:var(--info);">Retouch lần @r.RequestNumber</span>
                        </h6>
                        <small style="color:var(--text-muted);">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    @if (r.Status != PhoStudioMVC.Models.Enums.RetouchStatus.Completed)
                    {
                        <form asp-action="CompleteRetouch" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@r.Id" />
                            <button type="submit" class="btn btn-sm" style="background:var(--success);color:#fff;border:none;border-radius:8px;padding:7px 16px;font-weight:600;transition:all .25s ease;" onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
                                <i class="bi bi-check-circle me-1"></i>Đánh dấu đã retouch xong
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="badge" style="background:var(--success-bg);color:var(--success);padding:8px 14px;">✓ Hoàn thành</span>
                    }
                </div>

                <p style="color:var(--text-body);margin-bottom:8px;">@r.Note</p>

                @if (!string.IsNullOrEmpty(r.PhotoReference))
                {
                    <small style="color:var(--text-muted);"><i class="bi bi-image me-1"></i>Ảnh tham chiếu: @r.PhotoReference</small>
                }
            </div>
        }
    </div>
}
