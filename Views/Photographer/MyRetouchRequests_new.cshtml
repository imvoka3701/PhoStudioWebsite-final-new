@{
    Layout = "_PhotographerLayout";
    ViewData["Title"] = "Yêu Cầu Retouch";
}

<header>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h1 style="margin: 0; font-size: 2rem;">Yêu Cầu Retouch</h1>
            <p class="text-muted mb-0" style="font-weight: 300; font-size: 1rem;">Xem và xử lý các yêu cầu chỉnh sửa từ khách hàng.</p>
        </div>
    </div>
</header>

<!-- Retouch Requests Table -->
<div class="dash-card">
    <div style="border-bottom: 1px solid #E5E5E5; margin-bottom: 20px; padding-bottom: 16px;">
        <h4 style="margin: 0; color: #1F1F1F; font-weight: 600; font-size: 1.25rem;">
            <i class="bi bi-palette me-2"></i>Danh Sách Yêu Cầu Retouch
        </h4>
        <p class="text-muted small mb-0">Các yêu cầu chỉnh sửa ảnh từ khách hàng</p>
    </div>

    <div style="overflow-x: auto;">
        <table class="table table-premium">
            <thead>
                <tr>
                    <th>ID Yêu Cầu</th>
                    <th>Khách Hàng</th>
                    <th>Mô Tả Yêu Cầu</th>
                    <th>Ngày Tạo</th>
                    <th>Trạng Thái</th>
                    <th class="text-end">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>#RT001</strong></td>
                    <td>Nguyễn Văn A</td>
                    <td>Chỉnh sáng, cân bằng trắng</td>
                    <td>01/04/2026</td>
                    <td><span class="badge badge-warning">Chờ Xử Lý</span></td>
                    <td>
                        <button class="btn btn-sm" style="background: #3B82F6; color: white; border: none; border-radius: 4px; padding: 6px 12px;">Xem Chi Tiết</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>#RT002</strong></td>
                    <td>Trần Thị B</td>
                    <td>Xóa nốt ruồi, làm trắng da</td>
                    <td>31/03/2026</td>
                    <td><span class="badge badge-success">Hoàn Thành</span></td>
                    <td>
                        <button class="btn btn-sm" style="background: #3B82F6; color: white; border: none; border-radius: 4px; padding: 6px 12px;">Xem Chi Tiết</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>#RT003</strong></td>
                    <td>Phạm Minh C</td>
                    <td>Chỉnh sâu, tăng độ sắc nét</td>
                    <td>30/03/2026</td>
                    <td><span class="badge badge-success">Hoàn Thành</span></td>
                    <td>
                        <button class="btn btn-sm" style="background: #3B82F6; color: white; border: none; border-radius: 4px; padding: 6px 12px;">Xem Chi Tiết</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/photographer.js"></script>
}
