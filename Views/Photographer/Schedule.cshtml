@model IEnumerable<PhoStudioMVC.Models.Entities.Booking>
@{
    Layout = "_PhotographerLayout";
    ViewData["Title"] = "Lịch Làm Việc";
    var now = PhoStudioMVC.Utils.TimeHelper.VnNow;
}

@section Styles {
<style>
    /* ── Table overrides ── */
    .table-schedule { table-layout: fixed; width: 100%; }
    .table-schedule th, .table-schedule td { white-space: normal; word-break: break-word; vertical-align: middle; }
    .col-booking   { width: 140px; }
    .col-package   { width: 150px; }
    .col-note      { width: 180px; }
    .col-client    { width: 160px; }
    .col-commission{ width: 120px; }
    .col-status    { width: 130px; }
    .col-action    { width: 140px; }

    .note-cell { font-size:0.82rem; color:var(--text-muted); overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }

    /* ── Row states ── */
    .row-past     { background: rgba(245,239,230,0.6) !important; }
    .row-today    { background: rgba(203,163,92,0.08) !important; border-left: 3px solid var(--accent) !important; }
    .row-upcoming { background: #fff !important; }
    .row-past td, .row-today td, .row-upcoming td { border-color: var(--border-light) !important; }

    /* ── Page header ── */
    .photo-page-header {
        background: var(--bg-card);
        border-bottom: 1px solid var(--border-light);
        padding: 24px 32px;
        margin: -32px -32px 32px -32px;
        box-shadow: var(--shadow-sm);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
    }
</style>
}

    <div class="photo-page-header">
        <div>
            <h1 style="font-family:'Playfair Display',serif;font-size:1.75rem;font-weight:700;color:var(--text-dark);margin:0 0 4px 0;">
                Xin chào, @(User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User.Identity?.Name) 📷
            </h1>
            <p style="color:var(--text-muted);font-size:0.9rem;font-weight:300;margin:0;">Lịch trình tác nghiệp và quản lý album của bạn.</p>
        </div>
        <span style="font-size:0.85rem;color:var(--text-muted);"><i class="bi bi-calendar3 me-1"></i>@now.ToString("dd/MM/yyyy")</span>
    </div>

    <!-- Stats -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="dash-card border-info border-top border-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1" style="font-size:0.78rem;text-transform:uppercase;letter-spacing:.6px;color:var(--text-muted);font-weight:600;">Lịch Hẹn Của Tôi</p>
                        <h3 style="font-family:'Inter',sans-serif;font-size:2rem;font-weight:700;color:var(--text-dark);margin:0;">@Model.Count()</h3>
                    </div>
                    <i class="bi bi-calendar-check fs-3" style="color:var(--info);"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card border-warning border-top border-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1" style="font-size:0.78rem;text-transform:uppercase;letter-spacing:.6px;color:var(--text-muted);font-weight:600;">Đợi Tải Ảnh Lên</p>
                        <h3 style="font-family:'Inter',sans-serif;font-size:2rem;font-weight:700;color:var(--text-dark);margin:0;">@Model.Count(b => b.Status == PhoStudioMVC.Models.Enums.BookingStatus.ShootCompleted && b.CloudAlbum == null)</h3>
                    </div>
                    <i class="bi bi-cloud-arrow-up-fill fs-3" style="color:var(--warning);"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card border-top border-3" style="border-top-color:var(--accent)!important;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1" style="font-size:0.78rem;text-transform:uppercase;letter-spacing:.6px;color:var(--text-muted);font-weight:600;">Tiền Công Dự Kiến</p>
                        <h3 style="font-family:'Inter',sans-serif;font-size:1.6rem;font-weight:700;color:var(--accent);margin:0;">@Model.Where(b => b.Status == PhoStudioMVC.Models.Enums.BookingStatus.Deposited).Sum(b => b.CommissionAmount ?? 0).ToString("N0")đ</h3>
                    </div>
                    <i class="bi bi-cash-coin fs-3" style="color:var(--accent);"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card border-success border-top border-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1" style="font-size:0.78rem;text-transform:uppercase;letter-spacing:.6px;color:var(--text-muted);font-weight:600;">Tổng Thu Nhập Thực Tế</p>
                        <h3 style="font-family:'Inter',sans-serif;font-size:1.6rem;font-weight:700;color:var(--success);margin:0;">@Model.Where(b => b.Status == PhoStudioMVC.Models.Enums.BookingStatus.FullyPaid).Sum(b => b.CommissionAmount ?? 0).ToString("N0")đ</h3>
                    </div>
                    <i class="bi bi-wallet-fill fs-3" style="color:var(--success);"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Assigned Bookings Table -->
    <div class="dash-card mb-5">
        <h4 class="mb-4" style="font-family:'Playfair Display',serif;color:var(--text-dark);"><i class="bi bi-briefcase me-2" style="color:var(--info);"></i> Lịch Chụp Của Bạn</h4>
        <div class="alert alert-warning border-0 small mb-4" style="background:rgba(203,163,92,0.08);color:var(--text-body);border-radius:8px;">
            <i class="bi bi-info-circle me-1" style="color:var(--accent);"></i> Chỉ có thể "Hoàn tất chụp" sau khi thời gian lịch hẹn đã trôi qua.
        </div>
        <div class="table-responsive">
            <table class="table table-premium table-schedule">
                <thead>
                    <tr>
                        <th class="col-booking">Mã & Lịch Chụp</th>
                        <th class="col-package">Gói dịch vụ</th>
                        <th class="col-note">Ghi Chú</th>
                        <th class="col-client">Khách Hàng</th>
                        <th class="col-commission">Hoa Hồng (20%)</th>
                        <th class="col-status">Trạng Thái</th>
                        <th class="col-action text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody id="photo-booking-tbody">
                    @foreach (var booking in Model)
                    {
                        var canMarkAsCompleted = booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.Deposited &&
                            (booking.BookingDate.Date < now.Date || (booking.BookingDate.Date == now.Date && booking.StartTime <= now.TimeOfDay));
                        var hasPendingRetouch = booking.RetouchRequests != null &&
                            booking.RetouchRequests.Any(r => r.Status == PhoStudioMVC.Models.Enums.RetouchStatus.Pending);
                        
                        var isToday = booking.BookingDate.Date == now.Date;
                        var isPast = booking.BookingDate.Date < now.Date || (booking.BookingDate.Date == now.Date && booking.StartTime <= now.TimeOfDay);
                        var isUpcoming = !isPast;
                        var rowClass = isPast ? "row-past" : (isToday ? "row-today" : "row-upcoming");
                        
                        <tr class="@rowClass">
                            <td>
                                <div class="d-flex align-items-start gap-2">
                                    @if (isPast)
                                    {
                                        <i class="bi bi-check-circle-fill text-success mt-1 flex-shrink-0"></i>
                                    }
                                    else if (isToday)
                                    {
                                        <i class="bi bi-clock-fill mt-1 flex-shrink-0" style="color:var(--accent);"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-calendar-event text-info mt-1 flex-shrink-0"></i>
                                    }
                                    <div>
                                        <strong style="font-size:0.88rem;">@booking.BookingDate.ToString("dd/MM/yyyy")</strong>
                                        @if (isToday) { <span class="badge ms-1" style="background:rgba(203,163,92,0.15);color:var(--accent);font-size:0.7rem;">Hôm nay</span> }
                                        @if (isUpcoming && !isToday) { <span class="badge bg-info ms-1" style="font-size:0.7rem;">Sắp tới</span> }
                                        <div class="text-accent" style="font-size:0.8rem;">@booking.StartTime.ToString(@"hh\:mm") - @booking.EndTime.ToString(@"hh\:mm")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <strong style="font-size:0.88rem;">@(booking.ServicePackage?.Name ?? "N/A")</strong>
                                <div class="text-muted" style="font-size:0.8rem;">@((booking.ServicePackage?.Price ?? 0).ToString("N0"))đ</div>
                            </td>
                            <td><span class="note-cell">@booking.Notes</span></td>
                            <td>
                                <div style="font-size:0.88rem;font-weight:600;">@booking.Client?.FullName</div>
                                <div class="text-muted" style="font-size:0.8rem;">@booking.Client?.Phone</div>
                            </td>
                            <td>
                                @if (booking.CommissionAmount.HasValue)
                                {
                                    <strong class="text-success" style="font-size:0.9rem;">@booking.CommissionAmount.Value.ToString("N0")đ</strong>
                                }
                                else
                                {
                                    <span class="text-muted small">0đ</span>
                                }
                            </td>
                            <td>
                                @if (booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.TimeSlotLocked)
                                {
                                    <span class="badge bg-warning text-dark">Giữ chỗ</span>
                                }
                                else if (booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.Deposited)
                                {
                                    <span class="badge bg-info text-dark">Đã đặt cọc</span>
                                }
                                else if (booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.ShootCompleted)
                                {
                                    <span class="badge bg-primary">Đã chụp xong</span>
                                }
                                else if (booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.FullyPaid)
                                {
                                    <span class="badge bg-success">Hoàn thành</span>
                                }
                                else if (booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.Cancelled)
                                {
                                    <span class="badge bg-danger">Đã hủy</span>
                                }
                                @if (hasPendingRetouch)
                                {
                                    <span class="badge bg-danger d-block mt-1">Retouch pending</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.Deposited)
                                {
                                    <form asp-action="MarkShootCompleted" method="post" class="d-inline" onsubmit="return showLoading(this)">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success complete-btn"
                                                @(canMarkAsCompleted ? "" : "disabled=\"disabled\"")
                                                title="@(canMarkAsCompleted ? "Đánh dấu đã chụp xong" : "Chưa đến giờ chụp")">
                                            <span class="btn-text"><i class="bi bi-check-circle"></i> Đã Chụp Xong</span>
                                            <span class="btn-loading d-none"><i class="bi bi-hourglass-split"></i> Đang xử lý...</span>
                                        </button>
                                    </form>
                                }
                                else if ((booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.ShootCompleted
                                        || booking.Status == PhoStudioMVC.Models.Enums.BookingStatus.FullyPaid)
                                       && booking.CloudAlbum == null)
                                {
                                    <a asp-action="UploadAlbum" asp-route-bookingId="@booking.Id" 
                                       class="btn btn-sm btn-outline-warning"
                                       title="Tải album ảnh lên cho khách hàng">
                                        <i class="bi bi-cloud-upload me-1"></i>Upload Album
                                    </a>
                                }
                                else if (booking.CloudAlbum != null)
                                {
                                    <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Đã trả ảnh</span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Photographer Cloud Albums Creation Form -->
    <div class="dash-card mb-5">
        <h4 class="mb-2" style="font-family:'Playfair Display',serif;color:var(--text-dark);"><i class="bi bi-cloud-arrow-up me-2" style="color:var(--accent);"></i> Trả Ảnh Khách Hàng (Cloud Delivery)</h4>
        <p class="mb-4" style="color:var(--text-muted);font-size:0.9rem;">Chỉ được phép trả ảnh cho những lịch hẹn đã "Đã chụp xong" hoặc "Đã thanh toán đủ".</p>
        <form asp-action="DeliverAlbum" method="post" class="row g-3 p-4 rounded" style="background:var(--bg-secondary);border:1px solid var(--border-light);">
            @Html.AntiForgeryToken()
            <div class="col-md-4 mb-3 mb-md-0">
                <label class="form-label">Cấp Cho Lịch Hẹn (Hoàn Thành) *</label>
                <select name="bookingId" class="form-select" required>
                    <option value="">Chọn Mã Lịch Hẹn...</option>
                    @foreach(var b in Model.Where(x => (x.Status == PhoStudioMVC.Models.Enums.BookingStatus.ShootCompleted || x.Status == PhoStudioMVC.Models.Enums.BookingStatus.FullyPaid) && x.CloudAlbum == null))
                    {
                        <option value="@b.Id">@b.Client?.FullName - @b.BookingDate.ToString("dd/MM/yyyy") - @(b.ServicePackage?.Name ?? "N/A")</option>
                    }
                </select>
            </div>
            <div class="col-md-5 mb-3 mb-md-0">
                <label class="form-label">Đường dẫn Album Cloud (Google Drive / S3) *</label>
                <input type="url" name="albumUrl" class="form-control" placeholder="https://..." required>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-premium w-100">Cấp Quyền Trả Ảnh</button>
            </div>
        </form>
    </div>

    <!-- Manage My Albums Table -->
    <div class="dash-card">
        <h4 class="mb-4" style="font-family:'Playfair Display',serif;color:var(--text-dark);"><i class="bi bi-images me-2" style="color:var(--text-muted);"></i> Ảnh Đã Bàn Giao Của Bạn</h4>
        <div class="table-responsive">
            <table class="table table-premium text-nowrap">
                <thead>
                    <tr>
                        <th>Tên Album</th>
                        <th>Cấp Cho Khách</th>
                        <th>Ngày Bàn Giao</th>
                        <th class="text-end">Mã Bắt Bí (OTP)</th>
                    </tr>
                </thead>
                <tbody id="photo-albums-tbody">
                    @foreach (var b in Model.Where(x => x.CloudAlbum != null))
                    {
                        <tr>
                            <td>
                                <strong>Album @(b.ServicePackage?.Name ?? "Tùy chọn")</strong><br>
                                <span class="text-accent small"><a href="@b.CloudAlbum.AlbumUrl" target="_blank" class="text-info text-decoration-none"><i class="bi bi-box-arrow-up-right"></i> Mở Cloud</a></span>
                            </td>
                            <td>@b.Client?.FullName</td>
                            <td>@b.CloudAlbum.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end text-success fw-bold" style="letter-spacing: 2px;">@b.CloudAlbum.SecureOTP</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


@section Scripts {
    <script>
        function showLoading(form) {
            const button = form.querySelector('button[type="submit"]');
            button.querySelector('.btn-text').classList.add('d-none');
            button.querySelector('.btn-loading').classList.remove('d-none');
            button.disabled = true;
            return true;
        }

        document.addEventListener('DOMContentLoaded', function () {
            const tooltipEls = document.querySelectorAll('[title]');
            tooltipEls.forEach(el => new bootstrap.Tooltip(el));
        });
    </script>
    <script src="~/assets/js/photographer.js"></script>
}
