@{
    Layout = "_PhotographerLayout";
    ViewData["Title"] = "Tải Lên Album";
}

<header>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h1 style="margin: 0; font-size: 2rem;">Tải Lên Album</h1>
            <p class="text-muted mb-0" style="font-weight: 300; font-size: 1rem;">Tải album ảnh lên hệ thống để chia sẻ với khách hàng.</p>
        </div>
    </div>
</header>

<!-- Upload Form -->
<div class="dash-card mb-5">
    <div style="border-bottom: 1px solid #E5E5E5; margin-bottom: 20px; padding-bottom: 16px;">
        <h4 style="margin: 0; color: #1F1F1F; font-weight: 600; font-size: 1.25rem;">
            <i class="bi bi-cloud-arrow-up me-2"></i>Tải Lên Album Mới
        </h4>
        <p class="text-muted small mb-0">Chọn lịch hẹn và tải ảnh lên</p>
    </div>

    <form class="row gap-3" style="background: #FAFAF8; padding: 20px; border-radius: 8px;">
        <div class="col-md-4">
            <label class="form-label">Lịch Hẹn *</label>
            <select class="form-control" required>
                <option value="">-- Chọn Lịch Hẹn --</option>
                <option value="1">Phóng Sự Cưới - 15/03/2026</option>
                <option value="2">Ảnh Kỷ Yếu - 10/03/2026</option>
                <option value="3">Nàng Thơ - 05/03/2026</option>
            </select>
        </div>

        <div class="col-md-4">
            <label class="form-label">Tên Album *</label>
            <input type="text" class="form-control" placeholder="Vd: Phóng Sự Cưới Ngày 15/03" required>
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn w-100" style="background: #CBA35C; color: white; border: none; font-weight: 600; border-radius: 8px; padding: 10px 20px;">
                <i class="bi bi-cloud-arrow-up me-2"></i>Chọn Ảnh Để Tải Lên
            </button>
        </div>
    </form>
</div>

<!-- Uploaded Albums -->
<div class="dash-card">
    <div style="border-bottom: 1px solid #E5E5E5; margin-bottom: 20px; padding-bottom: 16px;">
        <h4 style="margin: 0; color: #1F1F1F; font-weight: 600; font-size: 1.25rem;">
            <i class="bi bi-images me-2"></i>Album Đã Tải Lên
        </h4>
        <p class="text-muted small mb-0">Danh sách các album đã được tải lên</p>
    </div>

    <div style="overflow-x: auto;">
        <table class="table table-premium">
            <thead>
                <tr>
                    <th>Tên Album</th>
                    <th>Lịch Hẹn</th>
                    <th>Số Ảnh</th>
                    <th>Ngày Tải Lên</th>
                    <th>Trạng Thái</th>
                    <th class="text-end">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Phóng Sự Cưới - 15/03</strong></td>
                    <td>Nguyễn Văn A & Trần Thị B</td>
                    <td><span style="color: #3B82F6; font-weight: 600;">150</span></td>
                    <td>20/03/2026</td>
                    <td><span class="badge badge-success">Đã Công Bố</span></td>
                    <td>
                        <button class="btn btn-sm" style="background: transparent; color: #3B82F6; border: 1px solid #3B82F6; border-radius: 4px; padding: 6px 12px;">Xem</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>Ảnh Kỷ Yếu Lớp</strong></td>
                    <td>Trường THPT ABC</td>
                    <td><span style="color: #3B82F6; font-weight: 600;">250</span></td>
                    <td>18/03/2026</td>
                    <td><span class="badge badge-warning">Chờ Duyệt</span></td>
                    <td>
                        <button class="btn btn-sm" style="background: transparent; color: #3B82F6; border: 1px solid #3B82F6; border-radius: 4px; padding: 6px 12px;">Xem</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>Nàng Thơ - Phạm Minh C</strong></td>
                    <td>Phạm Minh C</td>
                    <td><span style="color: #3B82F6; font-weight: 600;">85</span></td>
                    <td>12/03/2026</td>
                    <td><span class="badge badge-success">Đã Công Bố</span></td>
                    <td>
                        <button class="btn btn-sm" style="background: transparent; color: #3B82F6; border: 1px solid #3B82F6; border-radius: 4px; padding: 6px 12px;">Xem</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/photographer.js"></script>
}
