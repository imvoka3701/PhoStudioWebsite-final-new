@{
    Layout = "_Layout";
    ViewData["Title"] = "Trung Tâm Thông Báo";
}

@section Styles {
    <style>
        :root {
            --primary-color: #c9a96e;
            --dark-bg: #0f0f0f;
            --card-bg: rgba(30, 30, 30, 0.8);
            --border-color: rgba(201, 169, 110, 0.2);
            --text-muted: #999;
        }

        .notification-hero {
            padding: 100px 0 60px;
            background: linear-gradient(135deg, rgba(15,15,15,1) 0%, rgba(5,5,5,1) 100%);
            border-bottom: 1px solid var(--border-color);
        }

        .notification-hero h1 {
            font-size: 2.5rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 16px;
        }

        .notification-container {
            max-width: 900px;
            margin: 40px auto;
        }

        .notification-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .notification-filters {
            display: flex;
            gap: 12px;
        }

        .filter-btn {
            background: rgba(201, 169, 110, 0.1);
            color: var(--text-muted);
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .filter-btn.active {
            background: linear-gradient(135deg, var(--primary-color), #d4af7a);
            color: #000;
            border-color: var(--primary-color);
        }

        .filter-btn:hover {
            border-color: var(--primary-color);
        }

        .notification-actions {
            display: flex;
            gap: 8px;
        }

        .action-btn {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .action-btn:hover {
            border-color: var(--primary-color);
            color: var(--primary-color);
        }

        .notification-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .notification-item {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .notification-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background: var(--primary-color);
            transition: width 0.3s ease;
        }

        .notification-item:hover {
            border-color: var(--primary-color);
            box-shadow: 0 10px 30px rgba(201, 169, 110, 0.1);
        }

        .notification-item.unread {
            background: rgba(201, 169, 110, 0.05);
            border-left: 4px solid var(--primary-color);
        }

        .notification-item.unread::before {
            display: none;
        }

        .notification-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 12px;
        }

        .notification-title {
            display: flex;
            align-items: center;
            gap: 12px;
            flex: 1;
        }

        .notification-icon {
            font-size: 1.5rem;
            color: var(--primary-color);
            flex-shrink: 0;
        }

        .notification-title-text {
            font-weight: 700;
            color: #fff;
        }

        .notification-type {
            display: inline-block;
            background: rgba(201, 169, 110, 0.2);
            color: var(--primary-color);
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .notification-content {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.5;
            margin-bottom: 12px;
            margin-left: 40px;
        }

        .notification-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-left: 40px;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .notification-time {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .notification-actions-inline {
            display: flex;
            gap: 12px;
        }

        .action-link {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .action-link:hover {
            text-decoration: underline;
        }

        .empty-state {
            text-align: center;
            padding: 80px 40px;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
        }

        .empty-state-icon {
            font-size: 3rem;
            color: var(--primary-color);
            opacity: 0.5;
            margin-bottom: 20px;
        }

        .empty-state-title {
            color: #fff;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .empty-state-text {
            color: var(--text-muted);
        }

        .unread-badge {
            background: linear-gradient(135deg, #ff6b6b, #ff8787);
            color: #fff;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .notification-type-booking {
            background: rgba(74, 222, 128, 0.2);
            color: #4ade80;
        }

        .notification-type-payment {
            background: rgba(59, 130, 246, 0.2);
            color: #3b82f6;
        }

        .notification-type-album {
            background: rgba(168, 85, 247, 0.2);
            color: #a855f7;
        }

        .notification-type-review {
            background: rgba(249, 115, 22, 0.2);
            color: #f97316;
        }

        @@keyframes fadeOut {
            from {
                opacity: 1;
                transform: translateX(0);
            }
            to {
                opacity: 0;
                transform: translateX(20px);
            }
        }
    </style>
}

