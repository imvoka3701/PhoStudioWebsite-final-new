<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Phố Studio</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="~/assets/css/style.css">

    <style>
        body {
            background: linear-gradient(135deg, #F5EFE6 0%, #EDE0CC 50%, #F5EFE6 100%);
            min-height: 100vh;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
            position: relative;
        }

        .auth-card {
            background: #FFFFFF;
            border: 1px solid rgba(203,163,92,0.25);
            box-shadow: 0 20px 60px rgba(43,43,43,0.12), 0 4px 16px rgba(203,163,92,0.1);
            border-radius: 20px;
            padding: 48px 44px;
            width: 100%;
            max-width: 460px;
            z-index: 2;
        }

        /* Floating label — light theme */
        .custom-float .form-control {
            background: #FAF7F2;
            border: 1.5px solid #EDE8DF;
            border-radius: 10px;
            color: #2B2B2B;
            transition: border-color .25s ease, box-shadow .25s ease;
        }

        .custom-float .form-control:focus {
            background: #FFFFFF;
            border-color: #CBA35C;
            box-shadow: 0 0 0 3px rgba(203,163,92,0.15);
            color: #2B2B2B;
        }

        .custom-float label {
            color: #6B6B6B;
            padding-left: 12px;
        }

        .custom-float .form-control:focus ~ label,
        .custom-float .form-control:not(:placeholder-shown) ~ label {
            color: #CBA35C;
        }

        /* Override Bootstrap floating label background */
        .form-floating > label::after,
        .form-floating > .form-control:focus ~ label::after,
        .form-floating > .form-control:not(:placeholder-shown) ~ label::after {
            background-color: transparent !important;
            display: none !important;
        }

        .auth-card .form-floating > label {
            background-color: transparent !important;
            color: #6B6B6B;
        }

        .auth-card .form-floating > .form-control {
            background-color: #FAF7F2 !important;
        }

        .auth-card .form-floating > .form-control:focus {
            background-color: #FFFFFF !important;
        }

        /* Autofill fix */
        .form-floating > .form-control:-webkit-autofill {
            -webkit-box-shadow: 0 0 0 1000px #FAF7F2 inset !important;
            -webkit-text-fill-color: #2B2B2B !important;
        }

        .back-home {
            position: fixed;
            top: 20px;
            left: 20px;
            color: #2B2B2B;
            text-decoration: none;
            z-index: 10;
            font-size: 0.9rem;
            font-weight: 500;
            background: rgba(255,255,255,0.85);
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid #EDE8DF;
            transition: all .25s ease;
        }

        .back-home:hover {
            color: #CBA35C;
            border-color: #CBA35C;
            background: #fff;
        }

        /* Decorative gold accent bar at top of card */
        .auth-card::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #CBA35C, #d4af7a, #CBA35C);
            border-radius: 20px 20px 0 0;
            position: absolute;
            top: 0; left: 0; right: 0;
        }
        .auth-card { position: relative; overflow: hidden; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- Cinematic Loader -->
    <div id="loader" class="loader-screen">
        <div class="loader-logo">PHỐ</div>
    </div>

    <!-- Custom Interaction Cursor -->
    <div class="custom-cursor"></div>

    <a asp-controller="Home" asp-action="Index" class="back-home"><i class="bi bi-arrow-left me-2"></i>Trang Chủ</a>

    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="~/assets/js/main.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
