<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="@(ViewData["Description"] ?? "Studio nhiếp ảnh cao cấp chuyên chụp ảnh cưới, kỷ yếu và chân dung gia đình. Đội ngũ chuyên nghiệp, trang thiết bị hiện đại.")">
    <meta name="keywords" content="@(ViewData["Keywords"] ?? "nhiếp ảnh cưới, chụp ảnh cưới, studio ảnh cưới, nhiếp ảnh kỷ yếu, chụp ảnh kỷ yếu, chân dung gia đình, studio nhiếp ảnh, photographer tphcm")">
    <meta name="author" content="Phố Studio">
    <meta name="robots" content="index, follow">
    
    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content="@ViewData["Title"]">
    <meta property="og:description" content="@(ViewData["Description"] ?? "Studio nhiếp ảnh cao cấp chuyên chụp ảnh cưới, kỷ yếu và chân dung gia đình.")">
    <meta property="og:type" content="website">
    <meta property="og:url" content="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path">
    <meta property="og:image" content="@Context.Request.Scheme://@Context.Request.Host/assets/img/hero/home-hero.jpg">
    <meta property="og:site_name" content="Phố Studio">
    
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@ViewData["Title"]">
    <meta name="twitter:description" content="@(ViewData["Description"] ?? "Studio nhiếp ảnh cao cấp chuyên chụp ảnh cưới, kỷ yếu và chân dung gia đình.")">
    <meta name="twitter:image" content="@Context.Request.Scheme://@Context.Request.Host/assets/img/hero/home-hero.jpg">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path">
    
    <!-- Structured Data for SEO -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "LocalBusiness",
        "name": "Phố Studio",
        "description": "Studio nhiếp ảnh cao cấp chuyên chụp ảnh cưới, kỷ yếu và chân dung gia đình",
        "url": "@Context.Request.Scheme://@Context.Request.Host",
        "telephone": "0901 123 456",
        "email": "hello@phostudio.vn",
        "address": {
            "@@type": "PostalAddress",
            "streetAddress": "123 Nguyễn Huệ",
            "addressLocality": "Quận 1",
            "addressRegion": "TP.HCM",
            "addressCountry": "VN"
        },
        "geo": {
            "@@type": "GeoCoordinates",
            "latitude": "10.7769",
            "longitude": "106.7009"
        },
        "openingHours": "Mo-Su 09:00-21:00",
        "sameAs": [
            "https://www.facebook.com/phostudio",
            "https://www.instagram.com/phostudio"
        ],
        "serviceType": [
            "Nhiếp ảnh cưới",
            "Chụp ảnh kỷ yếu",
            "Chụp ảnh chân dung gia đình",
            "Nhiếp ảnh sản phẩm",
            "Chụp ảnh sự kiện"
        ],
        "priceRange": "$$$"
    }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- AOS Animation CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/assets/css/style.css?v=@DateTime.Now.Ticks@DateTime.Now.Millisecond@Guid.NewGuid().ToString("N")&cache=@Guid.NewGuid().ToString("N")">
    
    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- Cinematic Loader -->
    <div id="loader" class="loader-screen">
        <div class="loader-logo">PHỐ</div>
        <div class="loader-spinner mt-3"></div>
    </div>

    <!-- Custom Interaction Cursor -->
    <div class="custom-cursor"></div>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top navbar-premium">
        <div class="container">
            <a class="navbar-brand text-accent fw-bold fs-3" asp-controller="Home" asp-action="Index">PHỐ STUDIO</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang Chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Services">Dịch Vụ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Portfolio">Album Ảnh</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Booking" asp-action="Packages">Đặt Lịch</a></li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Client" asp-action="MyAlbums"><i class="bi bi-images me-1"></i> Album của tôi</a></li>
                        
                        if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-1"></i> Dashboard Admin</a></li>
                        }
                        else if (User.IsInRole("Photographer"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Photographer" asp-action="Schedule"><i class="bi bi-camera me-1"></i> Dashboard thợ chụp</a></li>
                        }
                    }
                    <li class="nav-item ms-lg-3 mt-3 mt-lg-0 d-flex align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <span class="text-accent me-3 fw-medium username-greeting"><i class="bi bi-person-circle me-1"></i> Xin chào, @(User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User.Identity.Name)</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">Đăng Xuất</button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-premium btn-sm">Đăng Nhập</a>
                        }
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Alert Container for notifications -->
    <div class="container alert-container">
        @{
            var successMsg = TempData["Success"]?.ToString() ?? TempData["SuccessMessage"]?.ToString();
            var errorMsg = TempData["Error"]?.ToString() ?? TempData["ErrorMessage"]?.ToString() ?? TempData["RegisterError"]?.ToString();
            var warningMsg = TempData["Warning"]?.ToString();
        }

        @if (!string.IsNullOrEmpty(successMsg))
        {
            <div class="alert alert-premium alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle-fill me-2"></i>@successMsg
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert alert-premium alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(warningMsg))
        {
            <div class="alert alert-premium alert-warning alert-dismissible fade show">
                <i class="bi bi-info-circle-fill me-2"></i>@warningMsg
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    @RenderBody()

    <!-- Footer -->
    <footer class="premium-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6 mb-4">
                    <h3 class="text-accent fw-bold mb-4">PHỐ STUDIO</h3>
                    <p class="text-muted pe-md-4">Studio nhiếp ảnh cao cấp tận tụy nắm bắt những khoảnh khắc thanh lịch và điện ảnh nhất trong cuộc sống.</p>
                    <div class="d-flex gap-3 mt-4">
                        <a href="javascript:void(0)" class="text-accent fs-5"><i class="bi bi-instagram"></i></a>
                        <a href="javascript:void(0)" class="text-accent fs-5"><i class="bi bi-facebook"></i></a>
                        <a href="javascript:void(0)" class="text-accent fs-5"><i class="bi bi-pinterest"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <h5 class="mb-4">Liên Kết Nhanh</h5>
                    <a asp-controller="Home" asp-action="Index" class="footer-link">Trang Chủ</a>
                    <a asp-controller="Home" asp-action="Services" class="footer-link">Dịch Vụ</a>
                    <a asp-controller="Home" asp-action="Portfolio" class="footer-link">Album Ảnh</a>
                    <a asp-controller="Booking" asp-action="Index" class="footer-link">Đặt Lịch</a>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5 class="mb-4">Cổng Khách Hàng</h5>
                    <a asp-controller="Account" asp-action="Login" class="footer-link">Đăng Nhập</a>
                    <a asp-controller="Client" asp-action="MyAlbums" class="footer-link">My Albums</a>
                    <a asp-controller="Admin" asp-action="Index" class="footer-link">Quản Trị Viên</a>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5 class="mb-4">Liên Hệ</h5>
                    <p class="text-muted mb-2"><i class="bi bi-geo-alt-fill text-accent me-2"></i> 123 Đường Phố Cổ, Hà Nội</p>
                    <p class="text-muted mb-2"><i class="bi bi-envelope-fill text-accent me-2"></i> hello@@phostudio.vn</p>
                    <p class="text-muted mb-2"><i class="bi bi-telephone-fill text-accent me-2"></i> +84 (0) 901 123 456</p>
                </div>
            </div>
            <div class="border-top border-secondary mt-5 pt-4 text-center">
                <p class="text-muted mb-0 small">&copy; 2026 Phố Studio. Bản quyền được bảo hộ.</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AOS Animation JS -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <!-- Custom JS -->
    <script src="~/assets/js/main.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
