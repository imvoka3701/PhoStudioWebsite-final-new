<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Phố Studio | Thợ Chụp</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/assets/css/admin-light-theme.css">
    <style>
        .photographer-wrapper { display: flex; min-height: 100vh; background: var(--bg-primary); }
        .photographer-sidebar {
            width: 250px; background: var(--bg-card); border-right: 1px solid var(--border-light);
            padding: 24px 16px; position: fixed; height: 100vh; overflow-y: auto;
            z-index: 1000; box-shadow: var(--shadow-sm);
        }
        .photographer-sidebar::-webkit-scrollbar { width: 4px; }
        .photographer-sidebar::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 2px; }
        .photographer-content {
            margin-left: 250px; padding: 32px; flex-grow: 1;
            width: calc(100% - 250px); background: var(--bg-primary);
        }
        .dash-nav-link {
            display: flex; align-items: center; gap: 10px; padding: 11px 14px;
            color: var(--text-body); text-decoration: none; border-radius: 10px;
            transition: all 0.25s ease; font-size: 0.9rem; font-weight: 500;
            margin-bottom: 4px; background: transparent; cursor: pointer;
        }
        .dash-nav-link:hover { background: var(--accent-light); color: var(--accent); transform: translateX(3px); }
        .dash-nav-link.active { background: var(--accent-light); color: var(--accent); border-left: 3px solid var(--accent); padding-left: 11px; font-weight: 600; }
        .dash-nav-link i { font-size: 1.1rem; }
        @@media (max-width: 768px) {
            .photographer-sidebar { width: 100%; height: auto; position: relative; border-right: none; border-bottom: 1px solid var(--border-light); display: none; }
            .photographer-sidebar.show { display: block; }
            .photographer-content { margin-left: 0; width: 100%; padding: 20px; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- Cinematic Loader -->
    <div id="loader" class="loader-screen">
        <div class="loader-logo">PHỐ</div>
    </div>

    <!-- Custom Interaction Cursor -->
    <div class="custom-cursor"></div>

    <div class="photographer-wrapper">
        <!-- Sidebar -->
        <aside class="photographer-sidebar" id="photographer-sidebar">
            <a asp-controller="Home" asp-action="Index" class="sidebar-brand">
                PHỐ STUDIO
                <span style="display:block;font-size:0.65rem;font-weight:300;color:var(--text-muted);letter-spacing:2px;text-transform:uppercase;margin-top:2px;">Cổng Thợ Chụp</span>
            </a>

            <div class="text-center mb-4 pb-4" style="border-bottom: 1px solid var(--border-light);">
                <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "Photographer")&background=c9a96e&color=fff"
                     class="rounded-circle mb-2" width="56" alt="Photographer Avatar">
                <p style="color:var(--text-dark);font-size:0.9rem;font-weight:500;margin:0;">@(User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User.Identity?.Name)</p>
                <span class="badge mt-1" style="background:var(--accent);color:#fff;font-size:0.65rem;">Thợ Chụp Ảnh</span>
            </div>

            <nav>
                <a asp-controller="Photographer" asp-action="Schedule" class="dash-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Schedule" ? "active" : "")">
                    <i class="bi bi-calendar-week me-2"></i> Lịch Làm Việc
                </a>
                <a asp-controller="Photographer" asp-action="Schedule" class="dash-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Schedule" ? "active" : "")">
                    <i class="bi bi-cloud-upload me-2"></i> Upload Album
                </a>
                <a asp-controller="Photographer" asp-action="MyRetouchRequests" class="dash-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MyRetouchRequests" ? "active" : "")">
                    <i class="bi bi-palette me-2"></i> Retouch Của Tôi
                </a>
                <a asp-controller="Photographer" asp-action="SelectedPhotos" class="dash-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SelectedPhotos" ? "active" : "")">
                    <i class="bi bi-heart me-2"></i> Ảnh khách đã chọn
                </a>

                <hr class="border-secondary my-3">

                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="dash-nav-link text-danger logout-btn w-100 border-0 bg-transparent text-start">
                        <i class="bi bi-box-arrow-left me-2"></i> Đăng Xuất
                    </button>
                </form>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="photographer-content">
            <!-- Mobile Toggle Header -->
            <div class="d-md-none d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px solid #E5E5E5;">
                <h4 class="mb-0" style="color: #CBA35C; font-weight: 700;">PHỐ STUDIO</h4>
                <button class="btn btn-outline-secondary" 
                        onclick="document.getElementById('photographer-sidebar').classList.toggle('show')"
                        style="border-color: #E5E5E5; color: #1F1F1F;">
                    <i class="bi bi-list fs-5"></i>
                </button>
            </div>

            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/main.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
